# GitHub Integration
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=ai-job-intelligence

# Groq LLM API
GROQ_API_KEY=gsk_your_groq_api_key_here

# Gmail SMTP Configuration
GMAIL_EMAIL=your_email@gmail.com
# Use an App Password, NOT your actual Gmail password
GMAIL_APP_PASSWORD=your_16_character_app_password

# n8n Configuration
N8N_HOST=your-n8n-instance-url-or-localhost
N8N_PROTOCOL=https
WEBHOOK_URL=https://your-n8n-instance-url
N8N_ENCRYPTION_KEY=generate-a-random-secret-key-here
